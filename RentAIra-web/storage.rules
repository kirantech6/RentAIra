rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // KYC Documents folder
    match /kyc/{userId}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Agreement PDFs folder
    match /agreements/{propertyId}/{fileName} {
      // Allow read if the user is logged in, but we can't easily check Firestore docs directly inside Storage rules without passing metadata 
      // or using token claims. A simpler secure approach: we encode tenantId and landlordId in metadata during upload.
      allow read: if request.auth != null && (
        resource == null || 
        resource.metadata.landlordId == request.auth.uid || 
        resource.metadata.tenantId == request.auth.uid
      );
      // Only Cloud Functions or Admin can write PDFs (they bypass rules)
      allow write: if false; 
    }
    
    // General property images
    match /properties/{propertyId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
